# ---------------------------------------------------------------------------
# Shortform Factory -- environment template
# Copy to .env and adjust. Anything left blank uses the default in the app.
# ---------------------------------------------------------------------------

# -- LLM (Qwen, OpenAI-compatible HTTP) -------------------------------------
QWEN_BASE_URL=http://192.168.22.31:8001/v1
QWEN_MODEL=qwen3-coder-next-q5km
QWEN_TIMEOUT_S=120
QWEN_MAX_TOKENS=4096

# -- ASR (WhisperX) ---------------------------------------------------------
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16
WHISPERX_BATCH_SIZE=16

# -- Diarization (pyannote) -------------------------------------------------
ENABLE_DIARIZATION=1
HUGGINGFACE_TOKEN=

# -- Vision (YOLOv11) -------------------------------------------------------
YOLO_MODEL_PATH=/models/yolov11n.pt
YOLO_DEVICE=cuda

# -- TTS (Vietnamese TTS Hub over HTTP) -------------------------------------
# The runner now delegates to the external Vietnamese TTS Hub (FastAPI app at
# TTS-master/api/app.py) over REST instead of loading F5-TTS in-process.
# Start the hub locally: `python3 -m uvicorn api.app:app --port 9090`.
TTS_HUB_URL=http://127.0.0.1:9090
# Per-request HTTP timeout (seconds).
TTS_HUB_TIMEOUT_S=120
# Hub `model=` field. Supported: f5, piper, auto_vn. Use "f5" for quality.
TTS_HUB_MODEL=f5
# Internal voice preset name, mapped to a hub tune_layers chain in
# services/tts/runner.py::_VOICE_PRESETS_HUB. Built-ins: default, narrator,
# male, female. Defaults to "male" per pipeline spec.
TTS_VOICE_VI=male

# -- Audio behavior ---------------------------------------------------------
# KEEP_ORIGINAL_AUDIO=1 (default) -- keep source audio; no TTS, no vocal separation.
# KEEP_ORIGINAL_AUDIO=0 -- enable TTS/vocal-sep stack (see TTS_REPLACE_AUDIO, KEEP_BACKGROUND_AUDIO).
KEEP_ORIGINAL_AUDIO=1

# -- Background-preserving voiceover splice (legacy; only used when KEEP_ORIGINAL_AUDIO=0) --
# When 1 (default), the render pipeline keeps the source's background music /
# SFX / ambient by running vocal source separation (Demucs by default, ffmpeg
# center-cancel as fallback) and mixing the Vietnamese TTS on top of the
# instrumental track instead of replacing the audio outright. Set to 0 to
# restore the old behaviour (full audio replacement, no background).
KEEP_BACKGROUND_AUDIO=1
# Gain (dB) applied to the preserved background while the TTS sits at 0 dB.
# Negative values duck the background so the voiceover stays intelligible.
BG_GAIN_DB=-8.0
# Separation engine: `demucs` (primary, GPU), `ffmpeg` (center-channel cancel
# fallback, no model required), or `off` (skip separation, full replacement).
VOCAL_SEPARATION=demucs
# Torch device for Demucs. Falls back to CPU automatically if CUDA absent.
DEMUCS_DEVICE=cuda

# -- Downloader (yt-dlp) ----------------------------------------------------
DOWNLOAD_COOKIES_FILE=
DOWNLOAD_FORMAT=bestvideo[height<=1080]+bestaudio/best
DOWNLOAD_OUTPUT_TEMPLATE=%(id)s.%(ext)s

# -- Redis ------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -- Database ---------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://factory:factory@postgres:5432/factory
DATABASE_URL_SYNC=postgresql+psycopg://factory:factory@postgres:5432/factory
POSTGRES_DB=factory
POSTGRES_USER=factory
POSTGRES_PASSWORD=factory

# -- Storage ----------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=/data/storage
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=1

# -- Mock toggles (1 = enable, short-circuits stage with a fixture) ---------
MOCK_DOWNLOAD=0
MOCK_ASR=0
MOCK_LLM=0
MOCK_RENDER=0
MOCK_YOLO=0

# -- Ports ------------------------------------------------------------------
API_PORT=8080
FRONTEND_PORT=3000

# -- Frontend ---------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SSE_URL=http://localhost:8080

# -- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO

# -- Facebook integration --------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8080/auth/facebook/callback
FACEBOOK_GRAPH_API_VERSION=v22.0
FACEBOOK_DAILY_LIMIT_PER_PAGE=10
FACEBOOK_MIN_DELAY_BETWEEN_POSTS_S=1800
REQUIRE_MANUAL_APPROVAL=true
TOKEN_ENCRYPTION_KEY=  # generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# -- YouTube discovery -----------------------------------------------------
YOUTUBE_DISCOVERY_MODE=yt_dlp  # yt_dlp | api
YOUTUBE_API_KEY=
YOUTUBE_MAX_RESULTS_PER_PAGE=10
YOUTUBE_MIN_DURATION_SECONDS=180
YOUTUBE_MAX_DURATION_SECONDS=1800
