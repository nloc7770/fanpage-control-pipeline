# Local dev: talk directly to the API on localhost.
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SSE_URL=http://localhost:8080

# Used only by next.config.mjs rewrites (server-side). In docker-compose this
# is the internal hostname of the api container (e.g. http://api:8080).
API_URL=http://localhost:8080
